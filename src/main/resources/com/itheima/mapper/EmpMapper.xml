<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
    MyBatis Mapper XML 映射文件
    知识点: namespace 必须与对应的 Mapper 接口全限定名一致, MyBatis 通过 namespace 关联接口与 XML
-->
<mapper namespace="com.itheima.mapper.EmpMapper">

    <!--
      条件分页查询员工列表 (联表查询部门名称)
      知识点:
        where 标签:
          1. 会自动根据条件是否成立, 来动态生成 where 关键字
          2. 会自动去除第一条条件前面多余的 and / or
        if 标签: test 属性为条件表达式, true 时拼接内部 SQL 片段
        concat 函数: MySQL 字符串拼接, 配合 like 实现模糊查询
        PageHelper 分页插件会自动拦截此 SQL, 追加 limit 分页子句
    -->
    <select id="list" resultType="com.itheima.pojo.Emp">
        select emp.*, dept.name deptName from emp left join dept on emp.dept_id = dept.id
        <where>
          <if test="name != null and name != ''">
              emp.name like concat('%', #{name}, '%')
          </if>
          <if test="gender != null">
              and emp.gender = #{gender}
          </if>
          <if test="begin != null and end != null">
              and emp.entry_date between #{begin} and #{end}
          </if>
        </where>
        order by emp.update_time desc
    </select>

    <!--
      批量删除员工信息
      知识点: foreach 标签遍历 ids 集合, 生成 in (?,?,?) 子句
    -->
    <delete id="deleteByIds">
        delete from emp where id in
        <foreach collection="ids" item = "id" open = "(" close=")" separator=",">
            #{id}
        </foreach>
    </delete>

    <!--
      自定义结果集 ResultMap
      知识点:
        ResultMap 用于处理复杂结果映射场景:
          - 数据库字段名与实体属性名不一致时手动映射
          - 一对多关联查询: 使用 collection 标签映射子集合
        id 标签: 主键映射 (性能优化, MyBatis 会缓存)
        result 标签: 普通字段映射, column 为数据库列名, property 为 Java 属性名
        collection 标签: 一对多映射
          - property: Emp 实体中的集合属性名 (exprList)
          - ofType: 集合中元素的类型
    -->
    <resultMap id="empResultMap" type="com.itheima.pojo.Emp">
        <id column="id" property="id" />
        <result column="username" property="username" />
        <result column="password" property="password" />
        <result column="name" property="name" />
        <result column="gender" property="gender" />
        <result column="phone" property="phone" />
        <result column="job" property="job" />
        <result column="salary" property="salary" />
        <result column="image" property="image" />
        <result column="entry_date" property="entryDate" />
        <result column="dept_id" property="deptId" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />

        <!--封装 exprList: 员工对应的工作经历列表 (一对多)-->
        <collection property="exprList" ofType="com.itheima.pojo.EmpExpr">
            <id column="ee_id" property="id"/>
            <result column="ee_company" property="company"/>
            <result column="ee_job" property="job"/>
            <result column="ee_begin" property="begin"/>
            <result column="ee_end" property="end"/>
            <result column="ee_empid" property="empId"/>
        </collection>
    </resultMap>

    <!--
      根据ID查询员工的详细信息 (含工作经历列表)
      知识点:
        左连接 LEFT JOIN: 即使员工没有工作经历也能查出基本信息
        别名: ee.id ee_id 防止与 emp.id 冲突, 同时供 ResultMap 的 column 引用
    -->
    <select id="getById" resultMap="empResultMap">
        select e.*,
        ee.id ee_id,
        ee.emp_id ee_empid,
        ee.begin ee_begin,
        ee.end ee_end,
        ee.company ee_company,
        ee.job ee_job
        from emp e left join emp_expr ee on e.id = ee.emp_id
        where e.id = #{id}
    </select>

    <!--
      根据ID动态更新员工信息
      知识点:
        set 标签:
          1. 生成 set 关键字
          2. 自动去除更新字段之后多余的逗号 (,)
        if 标签: 条件成立才拼接 SQL 片段, 实现按需更新 (只更新非空字段)
        最后无条件拼接 update_time 保证修改时间始终刷新
    -->
    <update id="updateById">
        update emp
        <set>
            <if test="username != null and username != ''">username = #{username},</if>
            <if test="password != null and password != ''">password = #{password},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="phone != null and phone != ''">phone = #{phone},</if>
            <if test="job != null">job = #{job},</if>
            <if test="salary != null">salary = #{salary},</if>
            <if test="image != null and image != ''">image = #{image},</if>
            <if test="entryDate != null">entry_date = #{entryDate},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="updateTime != null">update_time = #{updateTime}</if>
        </set>
        where id = #{id}
    </update>

    <!--
      统计各个职位的员工人数
      知识点:
        CASE WHEN 表达式: 将数字编码 (1,2,3...) 转换为中文职位名称
        GROUP BY + COUNT(*): 按职位分组统计
        ORDER BY total: 按人数排序
    -->
    <select id="countEmpJobData" resultType="java.util.Map">
        select
        (case job when 1 then '班主任'
        when 2 then '讲师'
        when 3 then '学工主管'
        when 4 then '教研主管'
        when 5 then '咨询师'
        else '其他' end)  pos,
        count(*) total
        from emp group by job
        order by total
    </select>

    <!--
      统计员工的性别信息
      知识点:
        if 函数: MySQL 内置条件函数 if(gender = 1, '男', '女')
        GROUP BY gender: 按性别分组统计
        返回 List<Map>, 每条 Map 包含 name(性别名称) 和 value(人数)
    -->
    <select id="countEmpGenderData" resultType="java.util.Map">
        select
        if(gender = 1, '男', '女') as name,
        count(*) as value
        from emp group by gender ;
    </select>
</mapper>
