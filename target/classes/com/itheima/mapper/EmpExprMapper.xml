<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itheima.mapper.EmpExprMapper">

    <!--
      批量插入工作经历
      知识点:
        foreach 标签 —— MyBatis 动态 SQL, 遍历集合生成多条 values
        collection: 遍历的集合参数名 (接口方法参数名或 @Param 指定的名称)
        item: 每次遍历出来的元素别名, 通过 #{expr.属性名} 取值
        separator: 每次循环之间的分隔符 (此处为逗号, 拼接为一条批量 INSERT)
        注意: begin 和 end 是 MySQL 关键字, 需要用反引号 `` 包裹
    -->
    <insert id="insertBatch">
        insert into emp_expr (emp_id, `begin`, `end`, company, `job`) values
        <foreach collection="exprList" item="expr" separator=",">
            (#{expr.empId}, #{expr.begin}, #{expr.end}, #{expr.company}, #{expr.job})
        </foreach>
    </insert>

    <!--
      根据员工的ID批量删除工作经历信息
      知识点:
        foreach 标签:
          collection: 遍历的集合参数名
          item: 遍历元素别名
          open: 循环开始前拼接的 SQL 片段 (左括号)
          close: 循环结束后拼接的 SQL 片段 (右括号)
          separator: 每次循环之间的分隔符 (逗号)
        最终生成: delete from emp_expr where emp_id in (1, 2, 3)
    -->
    <delete id="deleteByEmpIds">
        delete from emp_expr where emp_id in
        <foreach collection="empIds" item="empId" open="(" close=")" separator=",">
            #{empId}
        </foreach>
    </delete>

</mapper>
